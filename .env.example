# AcademiaOS environment configuration
# Copy to .env and fill in your values.

# Server
HOST=0.0.0.0
PORT=8000

# Claude CLI -- set your Anthropic API key for claude-code
ANTHROPIC_API_KEY=sk-ant-XXXX

# OpenRouter (optional fallback)
OPENROUTER_API_KEY=

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
